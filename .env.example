# Copy to ".env" and fill in secrets. Docker Compose and `load_dotenv()` read this file.

# --- GigaChat (Russian topics) — base64(client_id:client_secret) from Sber developer portal
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
# Optional: GIGACHAT_TEMPERATURE=0.3
# Dev only if TLS to GigaChat fails: GIGACHAT_VERIFY_SSL_CERTS=false

# Force backend: gigachat | ollama (overrides Russian detection)
# MODEL_ROUTE_OVERRIDE=

# --- Ollama (non-Russian topics)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:2b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TEMPERATURE=0.3

# --- LangSmith (https://smith.langchain.com) — traces LangGraph + LLM calls
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=article-agents
# Optional: LANGCHAIN_ENDPOINT= (self-hosted Smith)
# Optional: LANGCHAIN_TAGS=dev,batch
# Optional: LANGSMITH_TOPIC_PREVIEW_CHARS=200
# Optional: LANGSMITH_RUN_NAME_PREFIX=article
